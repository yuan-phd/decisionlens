# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Groq API key — required for the Eligibility Analyzer (Page 4).
# Get yours free at https://console.groq.com/keys
# If not set, the app will run in demo mode with mock AI responses.
GROQ_API_KEY=

# Root data directory. setup_data.py creates raw/ and processed/ inside it.
# Defaults to ./data if not set.
# Download instructions: https://aact.ctti-clinicaltrials.org/downloads
AACT_DATA_DIR=./data

# AACT credentials — register free at https://aact.ctti-clinicaltrials.org/users/sign_up
AACT_USERNAME=your_aact_username
AACT_PASSWORD=your_aact_password